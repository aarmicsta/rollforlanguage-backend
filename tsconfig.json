{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "#db/*": ["src/db/*"],
      "#services/*": ["src/services/*"],
      "#utils/*": ["src/utils/*"],
      "#config/*": ["src/config/*"],
      "#plugins/*": ["src/plugins/*"],
      "#validation/*": ["src/validation/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/types", "./node_modules/@types"]
  },
  "include": ["src", "src/types", "src/**/*"],
  "exclude": ["node_modules"]
}